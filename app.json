{
  "expo": {
    "name": "Football Manager",
    "slug": "football-manager",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/brand/icon.png",
    "splash": {
      "image": "./assets/brand/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0f1a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.footballmanager.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/adaptive-foreground.png",
        "backgroundColor": "#0f0f1a"
      },
      "package": "com.footballmanager.app"
    },
    "web": {
      "favicon": "./assets/brand/favicon.png"
    },
    "plugins": [
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Manrope-Regular.otf",
            "./assets/fonts/Manrope-SemiBold.otf",
            "./assets/fonts/Manrope-Bold.otf",
            "./assets/fonts/Manrope-ExtraBold.otf",
            "./assets/fonts/SairaCondensed-SemiBold.ttf",
            "./assets/fonts/SairaCondensed-Bold.ttf"
          ]
        }
      ]
    ]
  }
}
